@doc """
A byte offset with line and column numbers within a source file.
"""
struct Position
  column: Int
  line: Int
  offset: Int
end

@doc """
A source range defined by a start and stop position.
"""
struct Span
  start: Position
  stop: Position
end

extend Span
  fn new(start: Position, stop: Position) -> Span
    Span{start: start, stop: stop}
  end

  fn zero -> Span
    p = Position{offset: 0, line: 0, column: 0}
    Span{start: p, stop: p}
  end
end
