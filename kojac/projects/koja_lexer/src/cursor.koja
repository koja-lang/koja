alias KojaAST.Position

@doc """
A character-level cursor for scanning through source text.

Tracks byte offset, line, and column while providing single-character
peek and advance operations used by the lexer.
"""
struct Cursor
  chars: List<String>
  column: Int
  line: Int
  offset: Int

  @doc """
  Consumes the current character and advances offset, line, and column.
  Returns self unchanged if already at end-of-input.
  """
  fn advance(move self) -> Self
    if self.at_end?()
      return self
    end

    c = self.chars.get(self.offset).unwrap()
    self.offset += 1

    match c
      "\n" ->
        self.line += 1
        self.column = 1

      _ ->
        self.column += 1
    end

    self
  end

  @doc """
  Returns true if the cursor is past the end of the source text.
  """
  fn at_end?(self) -> Bool
    self.offset >= self.chars.length()
  end

  @doc """
  Returns the character at absolute index `i`, or None if out of bounds.
  """
  fn char_at(self, i: Int) -> Option<String>
    self.chars.get(i)
  end

  @doc """
  Creates a new cursor over the codepoints of `source`, starting at
  line 1, column 1.
  """
  fn new(source: String) -> Cursor
    Cursor{chars: source.codepoints(), column: 1, line: 1, offset: 0}
  end

  @doc """
  Returns the character at the current offset, or None at end-of-input.
  """
  fn peek(self) -> Option<String>
    self.chars.get(self.offset)
  end

  @doc """
  Returns the character one past the current offset, or None.
  """
  fn peek_next(self) -> Option<String>
    self.chars.get(self.offset + 1)
  end

  @doc """
  Returns the current position as a `Position` value.
  """
  fn position(self) -> Position
    Position{offset: self.offset, line: self.line, column: self.column}
  end

  @doc """
  Returns the source text between `start` and the current offset as a
  single string.
  """
  fn text_from(self, start: Int) -> String
    String.join(self.chars.slice(start, self.offset - start), "")
  end
end
