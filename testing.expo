struct Point
  x: Int
  y: Int
end

enum Color
  Red(Int, Int)
  Blue(Int)
end

fn main
  testing = Point{x: 5, y: 2}
  color = Color.Red(4, 5)

  match testing
    Point{x: 5} -> IO.puts("yo")
    _other -> IO.puts("nah")
  end

  match color
    Red(4, _) -> IO.puts("yo")
    _other -> IO.puts("nah")
  end
end
