(* ========================================================================== *)
(* Expo Language Grammar -- EBNF Specification                                *)
(* ========================================================================== *)
(*                                                                            *)
(* Notation:                                                                  *)
(*   { X }       = zero or more X                                             *)
(*   [ X ]       = optional X                                                 *)
(*   X | Y       = X or Y                                                     *)
(*   ( X )       = grouping                                                   *)
(*   "keyword"   = literal keyword / symbol                                   *)
(*   (* ... *)   = comment                                                    *)
(*                                                                            *)
(* Whitespace and newlines are significant as statement separators but are    *)
(* omitted from the grammar for readability. Newlines terminate statements;   *)
(* line continuation is implicit after binary operators, ".", and ",".        *)
(* ========================================================================== *)


(* ========================================================================== *)
(* 1. Program structure                                                       *)
(* ========================================================================== *)

(* Two entry points, one shared grammar. `.expo` files (compilation units in
   an `expo.toml` project) enter via `program` and contain only declarations
   -- the runtime entry point is the function (or Process type) named by
   the project's `entry = "..."` in `expo.toml`. `.exps` files (exposcript)
   enter via `script`, where bare statements are accepted at the top level;
   the driver hoists those statements into an implicit `fn main` before the
   rest of the pipeline. Every production below is shared between the two
   modes. *)

program = { top_level_decl } ;                              (* .expo *)
script  = { top_level_decl | statement } ;                  (* .exps *)

top_level_decl = struct_decl
               | enum_decl
               | protocol_decl
               | impl_block
               | extend_block
               | function_decl
               | constant_decl
               | type_alias_decl
               | alias_decl ;


(* ========================================================================== *)
(* 2. Type declarations                                                       *)
(* ========================================================================== *)

struct_member = struct_field | function_decl ;

struct_decl = { annotation } , "struct" , TYPE_IDENT , [ type_params ] ,
              { struct_member } ,
              "end" ;

struct_field = IDENT , ":" , type_expr , [ "=" , expr ] ;

enum_member = enum_variant | function_decl ;

enum_decl = { annotation } , "enum" , TYPE_IDENT , [ type_params ] ,
            { enum_member } ,
            "end" ;

enum_variant = TYPE_IDENT                                           (* unit *)
             | TYPE_IDENT , "(" , type_expr , { "," , type_expr } , ")"   (* tuple *)
             | TYPE_IDENT , "{" , struct_field , { "," , struct_field } , "}" ; (* struct *)

type_params = "<" , type_param , { "," , type_param } , ">" ;

type_param = TYPE_IDENT , [ ":" , TYPE_IDENT , { "&" , TYPE_IDENT } ] ;

type_alias_decl = { annotation } , "type" , TYPE_IDENT , "=" , type_expr ;

alias_decl = "alias" , alias_path , [ "as" , TYPE_IDENT ] ;

alias_path = { ( IDENT | TYPE_IDENT ) , "." } , TYPE_IDENT ;
(* Packages are PascalCase TYPE_IDENTs (e.g. `alias Net.TCPSocket`,        *)
(* `alias HTTP.Headers`). Lowercase IDENT segments are still accepted in   *)
(* leading positions for dotted paths that route through a non-package     *)
(* name, but every alias path must end with a TYPE_IDENT. The optional    *)
(* `as TYPE_IDENT` introduces a local rename.                              *)


(* ========================================================================== *)
(* 3. Protocols                                                               *)
(* ========================================================================== *)

protocol_decl = { annotation } , "protocol" , TYPE_IDENT , [ type_params ] ,
                { protocol_method } ,
                "end" ;

protocol_method = { annotation } , "fn" , IDENT , [ type_params ] ,
                  [ "(" , [ param_list ] , ")" ] , [ "->" , type_expr ] ,
                  [ { statement } , "end" ] ;


(* ========================================================================== *)
(* 4. Impl and extend blocks                                                  *)
(* ========================================================================== *)

(* `impl Protocol for Type` declares that Type implements Protocol. The `for`
   clause is required -- bare `impl Type` is rejected by the parser with a
   diagnostic pointing to `extend Type`.

   `extend Type` declares additional methods (and type aliases) on Type. The
   methods are ambient: callable from any package that can name Type. Two
   extend blocks declaring the same method name on the same type is a hard
   compile error, regardless of which packages they live in. *)

impl_block = "impl" , type_expr , "for" , type_expr ,
             { impl_member } ,
             "end" ;

extend_block = "extend" , type_expr ,
               { impl_member } ,
               "end" ;

impl_member = function_decl
            | type_alias ;

type_alias = "type" , TYPE_IDENT , "=" , type_expr ;


(* ========================================================================== *)
(* 5. Functions                                                               *)
(* ========================================================================== *)

function_decl = { annotation } , [ "priv" ] , "fn" , IDENT , [ type_params ] ,
                [ "(" , [ param_list ] , ")" ] , [ "->" , type_expr ] ,
                [ { statement } , "end" ] ;
                (* Body is optional: `@extern "C"` declarations omit the body and `end`. *)

param_list = param , { "," , param } ;

param = [ "move" ] , IDENT , ":" , type_expr , [ "=" , expr ]
      | [ "move" ] , "self" ;


(* ========================================================================== *)
(* 6. Type expressions                                                        *)
(* ========================================================================== *)

type_expr = primary_type_expr , { "|" , primary_type_expr } ;   (* union lowest precedence *)

primary_type_expr = "fn" , "(" , [ fn_type_param , { "," , fn_type_param } ] , ")" ,
                    "->" , type_expr                                        (* function *)
                  | named_type , "<" , type_expr , { "," , type_expr } , ">"  (* generic *)
                  | named_type                                              (* simple *)
                  | "Self"                                                  (* self type *)
                  | "(" , ")" ;                                             (* unit *)

fn_type_param = [ "move" ] , type_expr ;

named_type = TYPE_IDENT , { "." , TYPE_IDENT } ;

(* Primitive types are just named types: UInt8, UInt16, UInt32, UInt64, Int8,
   Int16, Int32, Int, Float32, Float, Bool, String. Option, Result, List,
   Map, Pair are generic named types. No special grammar rules needed. *)


(* ========================================================================== *)
(* 7. Expressions                                                             *)
(* ========================================================================== *)

statement = expr
          | assignment
          | compound_assign
          | return_stmt
          | break_stmt ;

lvalue = IDENT , { "." , IDENT } ;

assignment = IDENT , ":" , type_expr , "=" , expr
           | lvalue , "=" , expr
           | pattern , "=" , expr ;

return_stmt = "return" , [ expr ] ;

break_stmt = "break" ;

expr = ternary_expr ;

ternary_expr = or_expr , [ "?" , or_expr , ":" , or_expr ] ;
(* Note: else branch is or_expr, not ternary_expr -- nesting prohibited *)

or_expr = and_expr , { IDENT_OR , and_expr } ;
(* IDENT_OR = the identifier "or", recognized as an infix operator *)

and_expr = not_expr , { IDENT_AND , not_expr } ;
(* IDENT_AND = the identifier "and", recognized as an infix operator *)

not_expr = "not" , not_expr
         | comparison ;

comparison = addition , [ comp_op , addition ] ;

comp_op = "==" | "!=" | "<" | ">" | "<=" | ">=" ;

addition = multiplication , { ( "+" | "-" | "<>" ) , multiplication } ;

multiplication = unary , { ( "*" | "/" | "%" ) , unary } ;

unary = "-" , unary
      | postfix ;

postfix = primary , { postfix_op } ;

postfix_op = "." , IDENT , "(" , [ arg_list ] , ")"        (* method call *)
           | "." , IDENT                                   (* field access *)
           | "(" , [ arg_list ] , ")"  ;                   (* function call *)

arg_list = arg , { "," , arg } ;

arg = [ IDENT , ":" ] , expr ;    (* positional or keyword *)

primary = literal
        | IDENT
        | "self"
        | struct_construction
        | enum_construction
        | binary_literal
        | closure
        | short_closure
        
        | if_expr
        | unless_expr
        | match_expr
        | cond_expr
        | for_expr
        | loop_expr
        | while_expr
        | receive_expr
        | spawn_expr
        | "(" , expr , ")" ;                                 (* grouping *)

struct_construction = named_type , "{" ,
                      field_init , { "," , field_init } , [ "," ] ,
                      "}" ;

field_init = IDENT , ":" , expr ;

enum_construction = named_type , "." , TYPE_IDENT                     (* unit *)
                  | named_type , "." , TYPE_IDENT ,
                    "(" , expr , { "," , expr } , ")"                 (* tuple *)
                  | named_type , "." , TYPE_IDENT ,
                    "{" , field_init , { "," , field_init } , "}" ;   (* struct *)


(* ========================================================================== *)
(* 8. Closures                                                                *)
(* ========================================================================== *)

(* Full closure: fn (args) -> ReturnType body end *)
closure = "fn" , "(" , [ closure_params ] , ")" , [ "->" , type_expr ] ,
          { statement } ,
          "end" ;

closure_params = closure_param , { "," , closure_param } ;

closure_param = IDENT , [ ":" , type_expr ]
              | "(" , IDENT , { "," , IDENT } , ")"     (* destructured *)
              | "_" ;

(* Short arrow closure: (args -> expr) -- delimited by enclosing parens *)
short_closure = closure_param_short , "->" , expr ;

closure_param_short = IDENT , [ ":" , type_expr ]
                    | "(" , IDENT , { "," , IDENT } , ")"
                    | "_" ;

(* Function references are bare identifiers -- no sigil needed.
   Since Expo has no function overloading, a bare function name
   unambiguously refers to the function. foo() calls it, foo references it.
   This is handled by the IDENT rule in primary. *)


(* ========================================================================== *)
(* 9. Control flow                                                           *)
(* ========================================================================== *)

if_expr = "if" , expr ,
          { statement } ,
          [ "else" , { statement } ] ,
          "end" ;

unless_expr = "unless" , expr ,
              { statement } ,
              "end" ;

match_expr = "match" , expr ,
             { match_arm } ,
             "end" ;

match_arm = or_pattern , [ "when" , expr ] , "->" , match_body ;

or_pattern = pattern , { "|" , pattern } ;

match_body = statement
           | { statement } ;       (* multi-line arm *)

cond_expr = "cond" ,
            { cond_arm } ,
            "end" ;

cond_arm = expr , "->" , match_body ;

for_expr = "for" , pattern , "in" , expr ,
           { statement } ,
           "end" ;

loop_expr = "loop" ,
            { statement } ,
            "end" ;

while_expr = "while" , expr ,
             { statement } ,
             "end" ;


(* ========================================================================== *)
(* 10. Concurrency                                                            *)
(* ========================================================================== *)

(* spawn creates a new process; the type checker enforces the Process<C, M, R> constraint *)
spawn_expr = "spawn" , expr ;

(* receive blocks until a message arrives or the optional timeout expires.
   Arms use the same pattern -> body syntax as match. The after clause
   provides a timeout in milliseconds followed by a body block — no arrow. *)
receive_expr = "receive" ,
               { match_arm } ,
               [ "after" , expr , { statement } ] ,
               "end" ;


(* ========================================================================== *)
(* 11. Binary / bitstring literals                                            *)
(* ========================================================================== *)

binary_literal  = "<<" , [ binary_segment , { "," , binary_segment } ] , ">>" ;

binary_pattern  = "<<" , [ binary_pat_segment , { "," , binary_pat_segment } ] , ">>" ;

binary_segment  = expr , [ segment_modifier ]
                | expr , ":" , type_expr ;

binary_pat_segment = expr , [ segment_modifier ]
                   | expr , ":" , type_expr ;

segment_modifier = "::" , expr , [ "byte" ] , { modifier } ;

modifier = "signed" | "unsigned" | "big" | "little" ;

(* Size (::N) and type annotation (: Type) are mutually exclusive.           *)
(* Modifiers signed/unsigned/big/little are contextual identifiers, not      *)
(* reserved keywords.                                                        *)


(* ========================================================================== *)
(* 12. Pattern matching                                                       *)
(* ========================================================================== *)

pattern = "_"                                                       (* wildcard *)
        | literal                                                   (* literal *)
        | IDENT , ":" , type_expr                                   (* typed binding *)
        | IDENT                                                     (* binding *)
        | named_type , "." , TYPE_IDENT                             (* enum unit *)
        | named_type , "." , TYPE_IDENT ,
          "(" , pattern , { "," , pattern } , ")"                   (* enum tuple *)
        | named_type , "." , TYPE_IDENT ,
          "{" , [ field_pattern , { "," , field_pattern } ] , "}"   (* enum struct *)
        | TYPE_IDENT ,
          "{" , [ field_pattern , { "," , field_pattern } ] , "}"   (* plain struct *)
        | "[" , [ pattern , { "," , pattern } ] , "]"               (* list *)
        | binary_pattern                                             (* binary *)
        | TYPE_IDENT ,
          "(" , pattern , { "," , pattern } , ")" ;                 (* Some/Ok/Err *)

(* Field patterns are always `name: pattern` -- there is no shorthand   *)
(* form like `Point{x, y}`. To bind under the field's own name, write   *)
(* `x: x`. Unlisted fields are implicit wildcards.                      *)
field_pattern = IDENT , ":" , pattern ;


(* ========================================================================== *)
(* 13. Literals                                                               *)
(* ========================================================================== *)

literal = integer_lit
        | float_lit
        | string_lit
        | multiline_string_lit
        | bool_lit
        | list_lit
        | map_lit
        | "()" ;                                                    (* unit *)

integer_lit = DECIMAL_INT | HEX_INT | BIN_INT ;

DECIMAL_INT = DIGIT , { DIGIT | "_" } ;
HEX_INT     = "0x" , HEX_DIGIT , { HEX_DIGIT | "_" } ;
BIN_INT     = "0b" , BIN_DIGIT , { BIN_DIGIT | "_" } ;

float_lit = DECIMAL_INT , "." , DECIMAL_INT ;

string_lit = '"' , { string_char | interpolation } , '"' ;
string_char = escape_seq | any_char_except_quote_backslash_newline ;
escape_seq = "\\" , ( '"' | "\\" | "n" | "t" | "#" ) ;

multiline_string_lit = '"""' , { multiline_char | interpolation } , '"""' ;
multiline_char = escape_seq | any_char_except_triple_quote_backslash ;
(* Multiline strings support the same escape sequences as single-line strings.       *)
(* Indentation is stripped based on the closing """ column position:                 *)
(*   1. The first newline after the opening """ is consumed                          *)
(*   2. Leading spaces matching the closing """ indentation are stripped per line    *)
(*   3. The trailing newline before the closing """ is stripped                      *)

interpolation = "#{" , expr , [ ":" , FORMAT_SPEC ] , "}" ;

FORMAT_SPEC = { DIGIT | LOWER | UPPER | "." | "<" | ">" | "^" | "+" | "-" | "0" } ;

bool_lit = "true" | "false" ;

list_lit = "[" , [ expr , { "," , expr } , [ "," ] ] , "]" ;

map_lit  = "[" , ":" , "]"                                          (* empty map *)
         | "[" , expr , ":" , expr , { "," , expr , ":" , expr } , [ "," ] , "]" ;


(* ========================================================================== *)
(* 14. Operators                                                              *)
(* ========================================================================== *)

(* Precedence (lowest to highest):                                            *)
(*   1. or                                                                    *)
(*   2. and                                                                   *)
(*   3. not                                                                   *)
(*   4. ==  !=  <  >  <=  >=                                                  *)
(*   5. +  -  <>                                                              *)
(*   6. *  /  %                                                               *)
(*   7. unary -                                                               *)
(*   8. postfix: .fn()  .field  ()                                            *)
(*                                                                            *)
(* Assignment operators: =  +=  -=  *=  /=                                    *)

compound_assign = lvalue , ( "+=" | "-=" | "*=" | "/=" ) , expr ;


(* ========================================================================== *)
(* 15. Annotations                                                            *)
(* ========================================================================== *)

annotation = "@" , IDENT , [ annotation_value ] ;

annotation_value = string_lit
                 | multiline_string_lit
                 | "false" ;

(* Multiple annotations can appear on the same declaration, either stacked
   on separate lines or inline on the same line separated by whitespace:
     @link "argon2"          -- stacked
     @extern "C"
     struct Argon2C
   or:
     @link "argon2" @extern "C"   -- inline
     struct Argon2C
   The formatter normalizes inline spacing but preserves the stacked/inline
   choice. *)


(* ========================================================================== *)
(* 16. Comments                                                               *)
(* ========================================================================== *)

(* Line comments begin with # and extend to end of line.
   No block comment syntax. *)

comment = "#" , { any_char_except_newline } ;


(* ========================================================================== *)
(* 17. Other top-level declarations                                           *)
(* ========================================================================== *)

constant_decl = { annotation } , "const" , IDENT , [ ":" , type_expr ] , "=" , expr ;


(* ========================================================================== *)
(* 18. Lexical elements                                                       *)
(* ========================================================================== *)

IDENT       = LOWER , { LOWER | UPPER | DIGIT | "_" | "?" } ;
TYPE_IDENT  = UPPER , { LOWER | UPPER | DIGIT } ;

LOWER     = "a" | ... | "z" ;
UPPER     = "A" | ... | "Z" ;
DIGIT     = "0" | ... | "9" ;
HEX_DIGIT = DIGIT | "a" | ... | "f" | "A" | ... | "F" ;
BIN_DIGIT = "0" | "1" ;


(* ========================================================================== *)
(* Reserved keywords                                                          *)
(* ========================================================================== *)

(* after, alias, break, cond, const, else, end, enum, extend, false,    *)
(* fn, for, if, impl, in, loop, match, move, not, priv, protocol,        *)
(* receive, return, self, spawn, struct, true, type, unless, when, while *)
(*                                                                       *)
(* Note: `and`, `or`, and `as` are contextual identifiers, not reserved  *)
(* keywords. `and`/`or` are recognized as infix operators by the parser  *)
(* in expression context; `as` is recognized only inside `alias` decls.  *)
(* All three can be used as method/function names without restriction.   *)
