struct DecodeTest
  @test "decode null"
  fn test_decode_null -> Result<Bool, String>
    match Decoder.decode("null")
      Result.Ok(val) ->
        result = Encoder.encode(val)

        unless result == "null"
          return Result.Err("expected \"null\", got #{result}")
        end

      Result.Err(msg) ->
        return Result.Err("decode failed: #{msg}")
    end

    Result.Ok(true)
  end

  @test "decode true"
  fn test_decode_true -> Result<Bool, String>
    match Decoder.decode("true")
      Result.Ok(val) ->
        result = Encoder.encode(val)

        unless result == "true"
          return Result.Err("expected \"true\", got #{result}")
        end

      Result.Err(msg) ->
        return Result.Err("decode failed: #{msg}")
    end

    Result.Ok(true)
  end

  @test "decode integer"
  fn test_decode_integer -> Result<Bool, String>
    match Decoder.decode("42")
      Result.Ok(val) ->
        result = Encoder.encode(val)

        unless result == "42"
          return Result.Err("expected \"42\", got #{result}")
        end

      Result.Err(msg) ->
        return Result.Err("decode failed: #{msg}")
    end

    Result.Ok(true)
  end

  @test "decode string"
  fn test_decode_string -> Result<Bool, String>
    match Decoder.decode("\"hello\"")
      Result.Ok(val) ->
        result = Encoder.encode(val)

        unless result == "\"hello\""
          return Result.Err("expected '\"hello\"', got #{result}")
        end

      Result.Err(msg) ->
        return Result.Err("decode failed: #{msg}")
    end

    Result.Ok(true)
  end

  @test "decode empty array"
  fn test_decode_empty_array -> Result<Bool, String>
    match Decoder.decode("[]")
      Result.Ok(val) ->
        result = Encoder.encode(val)

        unless result == "[]"
          return Result.Err("expected \"[]\", got #{result}")
        end

      Result.Err(msg) ->
        return Result.Err("decode failed: #{msg}")
    end

    Result.Ok(true)
  end

  @test "decode array"
  fn test_decode_array -> Result<Bool, String>
    match Decoder.decode("[1, 2, 3]")
      Result.Ok(val) ->
        result = Encoder.encode(val)

        unless result == "[1,2,3]"
          return Result.Err("expected \"[1,2,3]\", got #{result}")
        end

      Result.Err(msg) ->
        return Result.Err("decode failed: #{msg}")
    end

    Result.Ok(true)
  end

  @test "decode object"
  fn test_decode_object -> Result<Bool, String>
    match Decoder.decode("{\"key\": \"value\"}")
      Result.Ok(val) ->
        result = Encoder.encode(val)

        unless result == "{\"key\":\"value\"}"
          return Result.Err("expected '{\"key\":\"value\"}', got #{result}")
        end

      Result.Err(msg) ->
        return Result.Err("decode failed: #{msg}")
    end

    Result.Ok(true)
  end

  @test "round trip object"
  fn test_round_trip -> Result<Bool, String>
    input = "{\"name\":\"koja\",\"version\":\"0.1.0\",\"tags\":[1,2,3]}"

    match Decoder.decode(input)
      Result.Ok(val) ->
        output = Encoder.encode(val)

        unless output == input
          return Result.Err("round trip failed: #{output}")
        end

      Result.Err(msg) ->
        return Result.Err("decode failed: #{msg}")
    end

    Result.Ok(true)
  end
end
