struct ParserTest
  @test "parse simple GET request"
  fn test_parse_get_request -> Result<Bool, String>
    raw = "GET /index.html HTTP/1.1\r\nHost: example.com\r\n\r\n"

    match Parser.parse_request(raw)
      Result.Ok(req) ->
        unless req.method.to_string() == "GET"
          return Result.Err("expected GET")
        end

        unless req.path == "/index.html"
          return Result.Err("expected /index.html")
        end

        unless req.version == "HTTP/1.1"
          return Result.Err("expected HTTP/1.1")
        end

        unless req.headers.get("Host").unwrap() == "example.com"
          return Result.Err("expected host example.com")
        end

        unless req.body == ""
          return Result.Err("expected empty body")
        end

      Result.Err(e) ->
        return Result.Err("parse failed: #{e.message()}")
    end

    Result.Ok(true)
  end

  @test "parse POST request with body"
  fn test_parse_post_request -> Result<Bool, String>
    raw = "POST /api/data HTTP/1.1\r\nHost: example.com\r\nContent-Length: 13\r\n\r\nHello, World!"

    match Parser.parse_request(raw)
      Result.Ok(req) ->
        unless req.method.to_string() == "POST"
          return Result.Err("expected POST")
        end

        unless req.path == "/api/data"
          return Result.Err("expected /api/data")
        end

        unless req.body == "Hello, World!"
          return Result.Err("expected body 'Hello, World!', got '#{req.body}'")
        end

      Result.Err(e) ->
        return Result.Err("parse failed: #{e.message()}")
    end

    Result.Ok(true)
  end

  @test "parse request with multiple headers"
  fn test_parse_multiple_headers -> Result<Bool, String>
    raw = "GET / HTTP/1.1\r\nHost: example.com\r\nAccept: text/html\r\nX-Custom: value\r\n\r\n"

    match Parser.parse_request(raw)
      Result.Ok(req) ->
        unless req.headers.get("Host").unwrap() == "example.com"
          return Result.Err("expected host")
        end

        unless req.headers.get("Accept").unwrap() == "text/html"
          return Result.Err("expected accept")
        end

        unless req.headers.get("X-Custom").unwrap() == "value"
          return Result.Err("expected custom header")
        end

      Result.Err(e) ->
        return Result.Err("parse failed: #{e.message()}")
    end

    Result.Ok(true)
  end

  @test "parse simple response"
  fn test_parse_response -> Result<Bool, String>
    raw = "HTTP/1.1 200 OK\r\nContent-Length: 5\r\n\r\nhello"

    match Parser.parse_response(raw)
      Result.Ok(resp) ->
        unless resp.status.code == 200
          return Result.Err("expected status 200")
        end

        unless resp.status.reason == "OK"
          return Result.Err("expected reason OK")
        end

        unless resp.version == "HTTP/1.1"
          return Result.Err("expected HTTP/1.1")
        end

        unless resp.body == "hello"
          return Result.Err("expected body hello")
        end

      Result.Err(e) ->
        return Result.Err("parse failed: #{e.message()}")
    end

    Result.Ok(true)
  end

  @test "parse response with multi-word reason"
  fn test_parse_response_multi_word_reason -> Result<Bool, String>
    raw = "HTTP/1.1 404 Not Found\r\nContent-Length: 9\r\n\r\nnot found"

    match Parser.parse_response(raw)
      Result.Ok(resp) ->
        unless resp.status.code == 404
          return Result.Err("expected status 404")
        end

        unless resp.status.reason == "Not Found"
          return Result.Err("expected reason 'Not Found', got '#{resp.status.reason}'")
        end

      Result.Err(e) ->
        return Result.Err("parse failed: #{e.message()}")
    end

    Result.Ok(true)
  end

  @test "parse response with no body"
  fn test_parse_response_no_body -> Result<Bool, String>
    raw = "HTTP/1.1 204 No Content\r\n\r\n"

    match Parser.parse_response(raw)
      Result.Ok(resp) ->
        unless resp.status.code == 204
          return Result.Err("expected status 204")
        end

        unless resp.body == ""
          return Result.Err("expected empty body, got '#{resp.body}'")
        end

      Result.Err(e) ->
        return Result.Err("parse failed: #{e.message()}")
    end

    Result.Ok(true)
  end

  @test "parse chunked response"
  fn test_parse_chunked_response -> Result<Bool, String>
    raw = "HTTP/1.1 200 OK\r\nTransfer-Encoding: chunked\r\n\r\n5\r\nhello\r\n6\r\n world\r\n0\r\n\r\n"

    match Parser.parse_response(raw)
      Result.Ok(resp) ->
        unless resp.body == "hello world"
          return Result.Err("expected 'hello world', got '#{resp.body}'")
        end

      Result.Err(e) ->
        return Result.Err("parse failed: #{e.message()}")
    end

    Result.Ok(true)
  end

  @test "parse empty request returns error"
  fn test_parse_empty_request -> Result<Bool, String>
    unless Parser.parse_request("").err?()
      return Result.Err("expected error for empty request")
    end

    Result.Ok(true)
  end

  @test "parse malformed request line returns error"
  fn test_parse_malformed_request_line -> Result<Bool, String>
    unless Parser.parse_request("BADREQUEST\r\n\r\n").err?()
      return Result.Err("expected error for malformed request line")
    end

    Result.Ok(true)
  end

  @test "Error.message returns readable description"
  fn test_error_message -> Result<Bool, String>
    e = Error.ParseError("bad header")

    unless e.message() == "parse error: bad header"
      return Result.Err("expected formatted message, got '#{e.message()}'")
    end

    Result.Ok(true)
  end
end
