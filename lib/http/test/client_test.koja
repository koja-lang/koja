struct ClientTest
  @test "request rejects an invalid URI before networking"
  fn test_request_invalid_uri -> Result<Bool, String>
    ClientTest.expect_invalid_url(
      "http://exa mple.com/",
      "invalid URI component",
    )
  end

  @test "request rejects an unsupported scheme before networking"
  fn test_request_unsupported_scheme -> Result<Bool, String>
    ClientTest.expect_invalid_url(
      "ftp://example.com/file",
      "unsupported URL scheme",
    )
  end

  @test "request rejects a missing host before networking"
  fn test_request_missing_host -> Result<Bool, String>
    ClientTest.expect_invalid_url("http:///path", "missing host")
  end

  priv fn expect_invalid_url(url: String, expected: String)
    -> Result<Bool, String>

    match request(Method.Get, url, Headers.new(), "")
      Result.Err(Error.InvalidUrl(message)) ->
        message.contains?(expected)
          ? Result.Ok(true)
          : Result.Err("expected '#{expected}' in '#{message}'")

      Result.Err(error) ->
        Result.Err("expected InvalidUrl, got '#{error.message()}'")

      Result.Ok(_) ->
        Result.Err("expected InvalidUrl for '#{url}'")
    end
  end
end
