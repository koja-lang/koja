struct ServerTest
  @test "Response.new sets Content-Length and version"
  fn test_response_new -> Result<Bool, String>
    resp = Response.new(Status.ok(), "hello")

    unless resp.status.code == 200
      return Result.Err("expected 200")
    end

    unless resp.version == "HTTP/1.1"
      return Result.Err("expected HTTP/1.1")
    end

    unless resp.headers.get("Content-Length").unwrap() == "5"
      return Result.Err("expected Content-Length 5")
    end

    unless resp.body == "hello"
      return Result.Err("expected body hello")
    end

    Result.Ok(true)
  end

  @test "Request.body_as_binary converts body"
  fn test_request_body_as_binary -> Result<Bool, String>
    req = Request{
      body: "test",
      headers: Headers.new(),
      method: Method.Get,
      path: "/",
      version: "HTTP/1.1",
    }
    bin = req.body_as_binary()

    unless bin.byte_size() == 4
      return Result.Err("expected 4 bytes, got #{bin.byte_size()}")
    end

    Result.Ok(true)
  end
end
