struct HMACTest
  @test "HMAC-SHA1 produces 20 bytes"
  fn test_hmac_sha1 -> Result<Bool, String>
    mac = HMAC.sha1("secret".to_binary(), "hello".to_binary())

    unless mac.byte_size() == 20
      return Result.Err("expected 20 bytes, got #{mac.byte_size()}")
    end

    Result.Ok(true)
  end

  @test "HMAC-SHA256 produces 32 bytes"
  fn test_hmac_sha256 -> Result<Bool, String>
    mac = HMAC.sha256("secret".to_binary(), "hello".to_binary())

    unless mac.byte_size() == 32
      return Result.Err("expected 32 bytes, got #{mac.byte_size()}")
    end

    Result.Ok(true)
  end

  @test "HMAC-SHA384 produces 48 bytes"
  fn test_hmac_sha384 -> Result<Bool, String>
    mac = HMAC.sha384("secret".to_binary(), "hello".to_binary())

    unless mac.byte_size() == 48
      return Result.Err("expected 48 bytes, got #{mac.byte_size()}")
    end

    Result.Ok(true)
  end

  @test "HMAC-SHA512 produces 64 bytes"
  fn test_hmac_sha512 -> Result<Bool, String>
    mac = HMAC.sha512("secret".to_binary(), "hello".to_binary())

    unless mac.byte_size() == 64
      return Result.Err("expected 64 bytes, got #{mac.byte_size()}")
    end

    Result.Ok(true)
  end
end
