struct SHA1Test
  @test "SHA1 one-shot digest"
  fn test_digest -> Result<Bool, String>
    d = SHA1.digest("hello".to_binary())

    unless d.byte_size() == 20
      return Result.Err("expected 20 bytes, got #{d.byte_size()}")
    end

    Result.Ok(true)
  end

  @test "SHA1 streaming matches one-shot"
  fn test_streaming -> Result<Bool, String>
    d1 = SHA1.digest("hello".to_binary())
    ctx = SHA1.new()
    ctx = ctx.update("hel".to_binary())
    ctx = ctx.update("lo".to_binary())
    d2 = ctx.finalize()

    unless d1.byte_size() == d2.byte_size()
      return Result.Err("size mismatch")
    end

    unless CPtr.borrow(d1).read() == CPtr.borrow(d2).read()
      return Result.Err("first byte mismatch")
    end

    Result.Ok(true)
  end

  @test "SHA1 empty input"
  fn test_empty -> Result<Bool, String>
    d = SHA1.digest("".to_binary())

    unless d.byte_size() == 20
      return Result.Err("expected 20 bytes for empty input")
    end

    Result.Ok(true)
  end
end

struct SHA256Test
