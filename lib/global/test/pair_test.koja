struct PairTest
  @test "Pair stores and retrieves int fields"
  fn test_pair_int -> Result<Bool, String>
    p = Pair{first: 10, second: 20}

    unless p.first == 10
      return Result.Err("expected first 10")
    end

    unless p.second == 20
      return Result.Err("expected second 20")
    end

    Result.Ok(true)
  end

  @test "Pair stores mixed types"
  fn test_pair_mixed -> Result<Bool, String>
    p = Pair{first: "hello", second: true}

    unless p.first == "hello"
      return Result.Err("expected first hello")
    end

    unless p.second == true
      return Result.Err("expected second true")
    end

    Result.Ok(true)
  end

  @test "Pair.new infers Option.None from return type"
  fn test_pair_new_contextual_none -> Result<Bool, String>
    pair = PairTest.empty_labelled()

    unless pair.first == 1 and pair.second.none?()
      return Result.Err("expected Pair(1, None)")
    end

    Result.Ok(true)
  end

  priv fn empty_labelled -> Pair<Int, Option<String>>
    Pair.new(1, Option.None)
  end
end
