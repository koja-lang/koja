alias File.Mode as FileMode

struct FdTest
  @test "close returns Ok on valid fd"
  fn test_close_ok -> Result<Bool, String>
    match File.open("/dev/null", FileMode.Read)
      Result.Ok(file) ->
        match file.fd.close()
          Result.Ok(_) -> Result.Ok(true)
          Result.Err(msg) -> Result.Err("expected Ok, got Err: #{msg}")
        end

      Result.Err(msg) ->
        Result.Err("failed to open /dev/null: #{msg}")
    end
  end

  @test "close consumes the fd"
  fn test_close_via_file -> Result<Bool, String>
    match File.open("/dev/null", FileMode.Read)
      Result.Ok(file) ->
        match file.close()
          Result.Ok(_) -> Result.Ok(true)
          Result.Err(msg) -> Result.Err("file close failed: #{msg}")
        end

      Result.Err(msg) ->
        Result.Err("failed to open /dev/null: #{msg}")
    end
  end

  @test "close on opened writable file"
  fn test_close_writable -> Result<Bool, String>
    path = "/tmp/koja_fd_close_test.txt"

    match File.open(path, FileMode.Write)
      Result.Ok(file) ->
        result = file.close()
        File.delete(path)

        match result
          Result.Ok(_) -> Result.Ok(true)
          Result.Err(msg) -> Result.Err("close writable failed: #{msg}")
        end

      Result.Err(msg) ->
        Result.Err("failed to open for write: #{msg}")
    end
  end

  @test "write returns byte count on success"
  fn test_write_ok -> Result<Bool, String>
    path = "/tmp/koja_fd_write_test.txt"

    match File.open(path, FileMode.Write)
      Result.Ok(file) ->
        match file.fd.write("hello")
          Result.Ok(n) ->
            File.delete(path)

            if n == 5
              Result.Ok(true)
            else
              Result.Err("expected 5 bytes written, got #{n}")
            end

          Result.Err(msg) ->
            File.delete(path)
            Result.Err("write failed: #{msg}")
        end

      Result.Err(msg) ->
        Result.Err("failed to open for write: #{msg}")
    end
  end

  @test "write and read back roundtrip"
  fn test_write_roundtrip -> Result<Bool, String>
    path = "/tmp/koja_fd_write_roundtrip.txt"

    match File.open(path, FileMode.Write)
      Result.Ok(file) ->
        file.fd.write("koja write test")

        match File.read(path)
          Result.Ok(contents) ->
            File.delete(path)

            if contents == "koja write test"
              Result.Ok(true)
            else
              Result.Err("expected 'koja write test', got '#{contents}'")
            end

          Result.Err(msg) ->
            File.delete(path)
            Result.Err("read back failed: #{msg}")
        end

      Result.Err(msg) ->
        Result.Err("failed to open for write: #{msg}")
    end
  end

  @test "write to /dev/null succeeds"
  fn test_write_devnull -> Result<Bool, String>
    match File.open("/dev/null", FileMode.Write)
      Result.Ok(file) ->
        match file.fd.write("discard me")
          Result.Ok(_) -> Result.Ok(true)
          Result.Err(msg) -> Result.Err("write to /dev/null failed: #{msg}")
        end

      Result.Err(msg) ->
        Result.Err("failed to open /dev/null: #{msg}")
    end
  end

  @test "watch and unwatch do not crash"
  fn test_watch_unwatch -> Result<Bool, String>
    match File.open("/dev/null", FileMode.Read)
      Result.Ok(file) ->
        file.fd.watch(0)
        file.fd.unwatch()
        _ = file.close()
        Result.Ok(true)

      Result.Err(msg) ->
        Result.Err("failed to open /dev/null: #{msg}")
    end
  end
end
