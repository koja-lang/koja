alias JSON.Decoder
alias JSON.Value

# Trimmed-down captures of real GitHub API payloads; `null` and
# missing keys exercise the zero-value folding in `Fields`.
const USER_JSON: String = "{\"login\": \"octocat\", \"name\": \"The Octocat\", \"company\": \"@github\", \"blog\": \"https://github.blog\", \"location\": \"San Francisco\", \"bio\": null, \"public_repos\": 8, \"followers\": 9999, \"following\": 9, \"created_at\": \"2011-01-25T18:44:36Z\"}"
const REPO_JSON: String = "{\"full_name\": \"octocat/Hello-World\", \"description\": \"My first repository on GitHub!\", \"fork\": false, \"language\": null, \"stargazers_count\": 2500, \"forks_count\": 1300, \"updated_at\": \"2026-06-01T12:00:00Z\"}"

struct FieldsTest
  @test "text folds null and missing keys to empty string"
  fn test_text_zero_values -> Result<Bool, String>
    value =
      match decode_fixture(USER_JSON)
        Result.Ok(v) -> v
        Result.Err(e) -> return Result.Err(e)
      end

    unless Fields.text(value, "bio") == ""
      return Result.Err("null bio should read as empty")
    end

    unless Fields.text(value, "no_such_key") == ""
      return Result.Err("missing key should read as empty")
    end

    Fields.text(value, "login") == "octocat"
      ? Result.Ok(true)
      : Result.Err("expected login to be octocat")
  end

  @test "number and flag read typed fields"
  fn test_number_and_flag -> Result<Bool, String>
    value =
      match decode_fixture(REPO_JSON)
        Result.Ok(v) -> v
        Result.Err(e) -> return Result.Err(e)
      end

    unless Fields.number(value, "stargazers_count") == 2500
      return Result.Err("expected 2500 stars")
    end

    unless Fields.number(value, "missing") == 0
      return Result.Err("missing number should read as 0")
    end

    Fields.flag(value, "fork")
      ? Result.Err("expected fork to be false")
      : Result.Ok(true)
  end
end

struct RenderTest
  @test "user payload renders a profile"
  fn test_render_user -> Result<Bool, String>
    value =
      match decode_fixture(USER_JSON)
        Result.Ok(v) -> v
        Result.Err(e) -> return Result.Err(e)
      end

    rendered = Cli.render_user(User.from_json(value))

    unless rendered.contains?("The Octocat (@octocat)")
      return Result.Err("missing title line in:\n" <> rendered)
    end

    unless rendered.contains?("joined: 2011-01-25")
      return Result.Err("missing joined date in:\n" <> rendered)
    end

    rendered.contains?("8 public repos · 9999 followers · 9 following")
      ? Result.Ok(true)
      : Result.Err("missing counts line in:\n" <> rendered)
  end

  @test "repo payload renders a detail view"
  fn test_render_repo -> Result<Bool, String>
    value =
      match decode_fixture(REPO_JSON)
        Result.Ok(v) -> v
        Result.Err(e) -> return Result.Err(e)
      end

    rendered = Cli.render_repo(Repo.from_json(value))

    unless rendered.contains?("octocat/Hello-World")
      return Result.Err("missing repo name in:\n" <> rendered)
    end

    unless rendered.contains?("stars: 2500")
      return Result.Err("missing stars in:\n" <> rendered)
    end

    rendered.contains?("My first repository on GitHub!")
      ? Result.Ok(true)
      : Result.Err("missing description in:\n" <> rendered)
  end

  @test "unknown commands and missing args fail with usage hints"
  fn test_dispatch_errors -> Result<Bool, String>
    match Cli.dispatch(["frobnicate"])
      Result.Ok(_) ->
        return Result.Err("unknown command should fail")

      Result.Err(e) ->
        unless e.contains?("unknown command: frobnicate")
          return Result.Err("unexpected message: " <> e)
        end
    end

    match Cli.dispatch(["user"])
      Result.Ok(_) ->
        Result.Err("missing login should fail")

      Result.Err(e) ->
        e.contains?("missing argument")
          ? Result.Ok(true)
          : Result.Err("unexpected message: " <> e)
    end
  end
end

priv fn decode_fixture(raw: String) -> Result<Value, String>
  match Decoder.decode(raw)
    Result.Ok(value) -> Result.Ok(value)
    Result.Err(e) -> Result.Err("fixture did not decode: " <> e)
  end
end
