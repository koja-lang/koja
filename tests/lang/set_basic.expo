fn main()
  s: Set<Int32> = Set.new()
  s = s.insert(10)
  s = s.insert(20)
  s = s.insert(10)

  print("length: #{s.length()}")
  print("has 10: #{s.has?(10)}")
  print("has 30: #{s.has?(30)}")
  print("empty: #{s.empty?()}")

  s = s.remove(10)
  print("after remove length: #{s.length()}")
  print("has 10 after remove: #{s.has?(10)}")
end
