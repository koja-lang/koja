fn main
  x = Option.Some(42)
  print(x.unwrap())
  print(x.or(0))
  print(x.some?())
  print(x.none?())

  y: Option<Int32> = Option.None
  print(y.or(99))
  print(y.some?())
  print(y.none?())

  s = Option.Some("hello")
  print(s.unwrap())
  print(s.or("default"))

  # map
  mapped = x.map(fn (v: Int32) -> Int32 v * 10 end)
  print(mapped.unwrap())
  none_mapped = y.map(fn (v: Int32) -> Int32 v * 10 end)
  print(none_mapped.or(-1))

  # then
  chained = Option.Some(10).then(fn (v: Int32) -> Option<Int32>
    Option.Some(v + 5)
  end)
  print(chained.unwrap())
  none_chained = y.then(fn (v: Int32) -> Option<Int32>
    Option.Some(v + 5)
  end)
  print(none_chained.or(-1))
end
