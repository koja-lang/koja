fn main
  print("hello world")
  print("tab:\there")
  print("quote: \"yes\"")
  print("backslash: \\")

  name = "expo"
  print("hello #{name}")
  print("1 + 2 = #{1 + 2}")

  msg = """first line
  second line"""
  print(msg)

  print("123456790".digit?())
  print("notdigit".digit?())
  print(" \n\r\t".whitespace?())
  print("notwhitespace ".whitespace?())
end
