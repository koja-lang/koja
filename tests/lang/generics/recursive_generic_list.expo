enum Val
  Num(Int)
  Arr(List<Val>)
end

fn main
  inner = [Val.Num(1), Val.Num(2)]
  v = Val.Arr(inner)
  match v
    Val.Num(n) ->
      print(n)

    Val.Arr(items) ->
      print(items.length())
      first = items.get(0)
      match first
        Option.Some(item) ->
          match item
            Val.Num(n) -> print(n)
            Val.Arr(_) -> print("nested arr")
          end

        Option.None ->
          print("empty")
      end
  end
end
