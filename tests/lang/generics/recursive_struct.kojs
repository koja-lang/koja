struct Node
  value: Int
  next: Option<Node>
end

leaf = Node{value: 3, next: Option.None}
mid = Node{value: 2, next: Option.Some(leaf)}
head = Node{value: 1, next: Option.Some(mid)}

head.value.print()

match head.next
  Option.Some(n) ->
    n.value.print()

    match n.next
      Option.Some(n2) -> n2.value.print()
      Option.None -> "none".print()
    end

  Option.None ->
    "none".print()
end
