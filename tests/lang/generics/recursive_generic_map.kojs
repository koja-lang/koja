enum JsonValue
  Null
  JBool(Bool)
  JInt(Int)
  JStr(String)
  JArr(List<JsonValue>)
  JObj(Map<String, JsonValue>)
end

obj: Map<String, JsonValue> = [
  "name": JsonValue.JStr("Koja"), "version": JsonValue.JInt(1)
]
v = JsonValue.JObj(obj)

match v
  JsonValue.JObj(m) ->
    result = m.get("name")

    match result
      Option.Some(name) ->
        match name
          JsonValue.JStr(s) -> s.print()
          _ -> "not a string".print()
        end

      Option.None ->
        "missing".print()
    end

  _ ->
    "not an object".print()
end
