fn identity<T>(x: T) -> T
  x
end

fn make_pair<A, B>(a: A, b: B) -> (A, B)
  (a, b)
end

identity(42).print()
identity("hello").print()
identity(true).print()

p = make_pair(10, 20)
(first, second) = p
first.print()
second.print()

p2 = make_pair("foo", 100)
(first, second) = p2
first.print()
second.print()
