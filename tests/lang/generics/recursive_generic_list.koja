enum Val
  Num(Int)
  Arr(List<Val>)
end

fn main
  inner = [Val.Num(1), Val.Num(2)]
  v = Val.Arr(inner)

  match v
    Val.Num(n) ->
      n.print()

    Val.Arr(items) ->
      items.length().print()
      first = items.get(0)

      match first
        Option.Some(item) ->
          match item
            Val.Num(n) -> n.print()
            Val.Arr(_) -> "nested arr".print()
          end

        Option.None ->
          "empty".print()
      end
  end
end
