struct GNode<T>
  value: T
  next: Option<GNode<T>>
end

fn main
  no_next: Option<GNode<Int>> = Option.None
  a = GNode{value: 10, next: no_next}
  b = GNode{value: 20, next: Option.Some(a)}
  b.value.print()

  match b.next
    Option.Some(n) -> n.value.print()
    Option.None -> "none".print()
  end
end
