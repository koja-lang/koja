fn identity<T>(x: T) -> T
  x
end

fn make_pair<A, B>(a: A, b: B) -> Pair<A, B>
  Pair{first: a, second: b}
end

fn main
  identity(42).print()
  identity("hello").print()
  identity(true).print()

  p = make_pair(10, 20)
  p.first.print()
  p.second.print()

  p2 = make_pair("foo", 100)
  p2.first.print()
  p2.second.print()
end
