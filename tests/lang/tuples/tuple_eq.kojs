# Structural equality on tuples: element-wise comparison through
# each element's Equality conformance, == / != operators, nesting,
# and derived struct elements.

((1, "a") == (1, "a")).print()
((1, "a") == (2, "a")).print()
((1, "a") == (1, "b")).print()
((1, "a") != (1, "b")).print()

# Nested tuples compare recursively.
((1, (2, 3)) == (1, (2, 3))).print()
((1, (2, 3)) == (1, (2, 4))).print()

# Bool and Float elements.
((true, 1.5) == (true, 1.5)).print()
((true, 1.5) == (false, 1.5)).print()

# Struct elements use their derived Equality impl.
struct Point
  x: Int
  y: Int
end

p = Point{x: 1, y: 2}
q = Point{x: 1, y: 2}
r = Point{x: 9, y: 9}

((p, "tag") == (q, "tag")).print()
((p, "tag") == (r, "tag")).print()

# Tuples bound to locals compare like inline literals.
left = (10, "ten")
right = (10, "ten")
(left == right).print()
