fn main
  nums: List<Int32> = [1, 2, 3, 4, 5]

  # map - same type
  doubled = nums.map(fn (n: Int32) -> Int32 n * 2 end)
  for d in doubled
    print(d)
  end

  # map - type change
  strings = nums.map(fn (n: Int32) -> String "item_#{n}" end)
  for s in strings
    print(s)
  end

  # filter
  big = nums.filter(fn (n: Int32) -> Bool n > 2 end)
  for b in big
    print(b)
  end

  # any? / all?
  has_big = nums.any?(fn (n: Int32) -> Bool n > 4 end)
  print(has_big)
  all_pos = nums.all?(fn (n: Int32) -> Bool n > 0 end)
  print(all_pos)
  all_big = nums.all?(fn (n: Int32) -> Bool n > 3 end)
  print(all_big)

  # chaining
  chained = nums.filter(fn (n: Int32) -> Bool n > 2 end).map(fn (n: Int32) -> Int32 n * 10 end)
  for c in chained
    print(c)
  end
end
