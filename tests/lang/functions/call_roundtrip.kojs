alias Process.Step
alias Process.StopReason

struct CalcConfig
end

enum CalcMsg
  Add(Int, Int)
end

struct Calc
end

impl Process<CalcConfig, CalcMsg, Int> for Calc
  fn start(config: CalcConfig) -> Result<Self, StopReason>
    Result.Ok(Calc{})
  end

  fn handle(self, msg: CalcMsg, from: Option<ReplyTo<Int>>) -> Step<Self>
    match msg
      CalcMsg.Add(a, b) ->
        sum = a + b
        "calc: #{sum}".print()

        ReplyTo.reply(from, sum)

        Step.Continue(self)
    end
  end
end

calc = spawn Calc.start(CalcConfig{})
result = calc.call(CalcMsg.Add(10, 32), 5000)

match result
  Result.Ok(n) -> "result: #{n}".print()
  Result.Err(_) -> "call failed!".print()
end
