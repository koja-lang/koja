fn apply(x: Int, f: fn (Int) -> Int) -> Int
  f(x)
end

fn apply_str(x: String, f: fn (String) -> String) -> String
  f(x)
end

# closure as inline argument with capture
base = 100
apply(5, fn (x: Int) -> Int x + base end).print()

# closure returning a string
prefix = "hello "
apply_str("world", fn (s: String) -> String prefix <> s end).print()

# chained closure calls
inc = fn (x: Int) -> Int x + 1 end

apply(apply(0, inc), inc).print()

# closure capturing multiple variables
a = 10
b = 20
c = 30
apply(1, fn (x: Int) -> Int x + a + b + c end).print()

# closure that ignores its parameter
apply(999, fn (x: Int) -> Int 42 end).print()
