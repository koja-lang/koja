fn apply(x: Int, f: fn (Int) -> Int) -> Int
  f(x)
end

fn apply_str(s: String, f: fn (String) -> String) -> String
  f(s)
end

# basic: short closure passed inline to a typed function
apply(5, x -> x * 2).print()

# short closure with string param inferred from context
apply_str("world", s -> "hello " <> s).print()

# wildcard param
apply(999, _ -> 42).print()

# short closure capturing a variable
offset = 100
apply(5, x -> x + offset).print()

# chained application
apply(apply(1, x -> x + 1), x -> x * 3).print()

# option.map with short closure
opt = Option.Some(7)
mapped = opt.map(v -> v * 10)
mapped.unwrap().print()

# option.map on None
none_opt: Option<Int> = Option.None
none_mapped = none_opt.map(v -> v * 10)
(none_mapped.or(-1)).print()
