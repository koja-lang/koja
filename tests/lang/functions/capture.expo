fn apply(x: Int, f: fn (Int) -> Int) -> Int
  f(x)
end

fn main
  multiplier = 3

  triple =
    fn (x: Int) -> Int x * multiplier end

  triple(4).print()
  triple(10).print()

  offset = 100
  scale = 2

  transform =
    fn (x: Int) -> Int x * scale + offset end

  transform(5).print()

  apply(7, fn (n: Int) -> Int n + offset end).print()
end
