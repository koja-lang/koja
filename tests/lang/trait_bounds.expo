protocol Greeter
  fn greet(self) -> String
end

struct Dog
  name: String
end

struct Cat
  name: String
end

impl Greeter for Dog
  fn greet(self) -> String
    "Woof! I'm #{self.name}"
  end
end

impl Greeter for Cat
  fn greet(self) -> String
    "Meow! I'm #{self.name}"
  end
end

fn say_hello<T: Greeter>(animal: T) -> String
  animal.greet()
end

protocol Description
  fn describe(self) -> String
end

impl Description for Dog
  fn describe(self) -> String
    "Dog(#{self.name})"
  end
end

fn describe_and_greet<T: Greeter & Description>(animal: T) -> String
  animal.describe() <> " says " <> animal.greet()
end

fn main
  dog = Dog{name: "Rex"}
  cat = Cat{name: "Whiskers"}

  print(say_hello(dog))
  print(say_hello(cat))

  dog2 = Dog{name: "Buddy"}
  print(describe_and_greet(dog2))
end
