alias Process.Lifecycle
alias Process.Step
alias Process.StopReason

# Regression: a spawned process's heap-bearing config and state must
# be fully reclaimed after a graceful shutdown. Covers the spawn-blob
# drop glue (config transferred to the runtime), the spawn wrapper
# releasing the state `start` returns, and the deep-copy of the config
# at the spawn site.

struct Rt
  @extern "C"
  fn koja_rt_live_blocks -> Int64
end

struct EchoConfig
  name: String
  tags: List<String>
end

struct Echo
  name: String
end

impl Process<EchoConfig, Int, Int> for Echo
  fn start(config: EchoConfig) -> Result<Self, StopReason>
    Result.Ok(Echo{name: config.name})
  end

  fn handle(self, msg: Int, from: Option<ReplyTo<Int>>) -> Step<Self>
    ReplyTo.reply(from, msg + 1)
    Step.Continue(self)
  end
end

fn spawn_once
  r = spawn Echo.start(
    EchoConfig{name: "n" <> "ame", tags: ["a" <> "b", "c" <> "d"]},
  )
  _ = r.call(1, 5000)
  r.signal(Lifecycle.Shutdown)

  loop
    if r.alive?()
      ()
    else
      break
    end
  end
end

spawn_once()
start = Rt.koja_rt_live_blocks()

i = 0

loop
  spawn_once()
  i += 1

  if i >= 100
    break
  end
end

# A dead process's resources are dropped off-lock by the worker that
# ran it, so alive?() flipping false can precede the final drops by a
# moment. Re-read briefly before declaring a leak.
finish = Rt.koja_rt_live_blocks()
attempts = 0

loop
  if finish - start < 10 or attempts >= 100000
    break
  end

  attempts += 1
  finish = Rt.koja_rt_live_blocks()
end

if finish - start < 10
  "spawn reclaim: ok".print()
else
  "spawn reclaim: LEAK".print()
  (finish - start).print()
end
