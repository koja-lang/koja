fn main
  # basic round-trip
  s = "hello world"
  cs = s.to_cstring()
  print(cs.len)
  back = cs.to_string()
  print(back)
  print(back == s)
  cs.free()

  # empty string
  empty = ""
  cs2 = empty.to_cstring()
  print(cs2.len)
  back2 = cs2.to_string()
  print(back2 == "")
  cs2.free()

  # string with special characters
  special = "hello\tworld\n"
  cs3 = special.to_cstring()
  print(cs3.len)
  back3 = cs3.to_string()
  print(back3 == special)
  cs3.free()

  # longer string
  long = "the quick brown fox jumps over the lazy dog"
  cs4 = long.to_cstring()
  print(cs4.len)
  back4 = cs4.to_string()
  print(back4)
  cs4.free()

  # original string is unaffected after conversion
  original = "unchanged"
  cs5 = original.to_cstring()
  print(original)
  cs5.free()

  print("done")
end
