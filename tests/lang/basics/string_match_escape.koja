struct LineInfo
  number: Int
  raw: String
end

fn render(line: String) -> String
  result = ""

  for c in line
    match c
      "\t" -> result = result <> "\\t"
      "\n" -> result = result <> "\\n"
      "\"" -> result = result <> "\\\""
      _ -> result = result <> c
    end
  end

  result
end

fn main
  l1 = LineInfo{number: 1, raw: "hello\tworld"}
  l2 = LineInfo{number: 2, raw: "quote\"in\"middle"}
  l3 = LineInfo{number: 3, raw: "no_escape"}

  render(l1.raw).print()
  render(l2.raw).print()
  render(l3.raw).print()

  l1.raw.escape_debug().print()
  l1.format().print()
end
