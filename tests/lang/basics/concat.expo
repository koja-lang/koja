fn main
  a = "hello"
  b = " world"
  c = a <> b
  print(c)

  x = "foo" <> "bar" <> "baz"
  print(x)

  bin1: Binary = <<1, 2>>
  bin2: Binary = <<3, 4>>
  bin3 = bin1 <> bin2
  match bin3
    <<1, 2, 3, 4>> -> print("binary concat ok")
    _ -> print("binary concat fail")
  end

  empty: Binary = <<>>
  full = empty <> <<5>>
  match full
    <<5>> -> print("empty concat ok")
    _ -> print("empty concat fail")
  end
end
