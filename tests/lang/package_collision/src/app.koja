alias Alpha.Config as AlphaConfig
alias Beta.Config as BetaConfig
alias Alpha.Status as AlphaStatus
alias Beta.Status as BetaStatus

struct App
end

impl Process<(), (), ()> for App
  fn start(config: ()) -> Result<Self, StopReason>
    Result.Ok(App{})
  end

  fn handle(self, msg: (), from: Option<ReplyTo<()>>) -> Step<Self>
    Step.Continue(self)
  end

  fn run(self) -> StopReason
    a = AlphaConfig.new(42)
    b = BetaConfig.new("hello")

    a.value.print()
    b.label.print()
    a.describe().print()
    b.describe().print()

    s1 = AlphaStatus.Ready
    s2 = AlphaStatus.Busy(7)
    s3 = BetaStatus.Online("localhost")
    s4 = BetaStatus.Offline

    s1.describe().print()
    s2.describe().print()
    s3.describe().print()
    s4.describe().print()

    s1.format().print()
    s3.format().print()
    a.format().print()
    b.format().print()
    StopReason.Normal
  end
end
