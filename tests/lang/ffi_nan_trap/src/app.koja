# A C function that returns NaN must trap at the call site: Float
# is finite-only and FFI is the one boundary where foreign
# non-finite values could otherwise leak in.

alias Process.Step
alias Process.StopReason

struct FFI
  @extern "C" @link "ffi_helper"
  fn nan_c() -> Float64
end

struct App
end

impl Process<(), (), ()> for App
  fn start(config: ()) -> Result<Self, StopReason>
    Result.Ok(App{})
  end

  fn handle(self, msg: (), from: Option<ReplyTo<()>>) -> Step<Self>
    Step.Continue(self)
  end

  fn run(self) -> StopReason
    poison: Float = FFI.nan_c()
    poison.print()
    StopReason.Normal
  end
end
