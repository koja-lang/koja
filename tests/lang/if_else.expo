fn classify(n: Int32) -> String
  cond
    n > 100 -> "big"
    n > 10 -> "medium"
    else -> "small"
  end
end

fn main
  if true
    print("yes")
  end

  if false
    print("nope")
  else
    print("else branch")
  end

  x = 5
  if x > 3
    print("greater")
  else
    print("not greater")
  end

  y = x > 2 ? "big" : "small"
  print(y)

  print(classify(200))
  print(classify(50))
  print(classify(3))
end
