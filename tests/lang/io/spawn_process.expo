struct WorkerConfig
  label: String
end

enum WorkerMsg
  Greet(String)
  Add(Int, Int)
  Stop
end

struct Worker
  label: String
end

impl Process<WorkerConfig, WorkerMsg, String> for Worker
  fn new(config: WorkerConfig) -> Self
    Worker{label: config.label}
  end

  fn handle(move self, msg: WorkerMsg, from: Option<ReplyTo<String>>) -> Self | StopReason
    match msg
      WorkerMsg.Greet(name) ->
        print("#{self.label}: Hello, #{name}!")
        self

      WorkerMsg.Add(a, b) ->
        result = a + b
        print("#{self.label}: Sum: #{result}")
        self

      WorkerMsg.Stop ->
        print("#{self.label}: Stopped.")
        match from
          Option.Some(r) -> r.send("done")
          Option.None -> ()
        end
        self
    end
  end
end

fn main
  w = spawn Worker.new(WorkerConfig{label: "w1"})
  w.cast(WorkerMsg.Greet("Expo"))
  w.cast(WorkerMsg.Add(10, 32))
  # Last message uses call to ensure the worker finishes before main exits.
  w.call(WorkerMsg.Stop, 5000)
end
