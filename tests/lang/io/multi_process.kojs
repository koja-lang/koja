alias Process.Step
alias Process.StopReason

enum PingMsg
  Ping(String)
  Stop
end

struct Ponger
  label: String
end

impl Process<Ponger, PingMsg, String> for Ponger
  fn start(config: Ponger) -> Result<Self, StopReason>
    Result.Ok(config)
  end

  fn handle(self, msg: PingMsg, from: Option<ReplyTo<String>>) -> Step<Self>
    match msg
      PingMsg.Ping(name) ->
        match from
          Option.Some(r) -> r.send("pong #{name}")
          Option.None -> ()
        end

        Step.Continue(self)

      PingMsg.Stop ->
        match from
          Option.Some(r) -> r.send("bye")
          Option.None -> ()
        end

        Step.Done(StopReason.Normal)
    end
  end
end

enum CoordMsg
  RunTest
  Done
end

struct Coordinator
  label: String
end

impl Process<Coordinator, CoordMsg, String> for Coordinator
  fn start(config: Coordinator) -> Result<Self, StopReason>
    Result.Ok(config)
  end

  fn handle(self, msg: CoordMsg, from: Option<ReplyTo<String>>) -> Step<Self>
    match msg
      CoordMsg.RunTest ->
        p = spawn Ponger.start(Ponger{label: "ponger"})
        ping_result = p.call(PingMsg.Ping("multi"), 5000)

        match ping_result
          Result.Ok(v) -> "ping: #{v}".print()
          Result.Err(_) -> "ping: failed".print()
        end

        stop_result = p.call(PingMsg.Stop, 5000)

        match stop_result
          Result.Ok(v) -> "stop: #{v}".print()
          Result.Err(_) -> "stop: failed".print()
        end

        match from
          Option.Some(r) -> r.send("done")
          Option.None -> ()
        end

        Step.Continue(self)

      CoordMsg.Done ->
        match from
          Option.Some(r) -> r.send("shutting down")
          Option.None -> ()
        end

        Step.Done(StopReason.Normal)
    end
  end
end

c = spawn Coordinator.start(Coordinator{label: "coord"})
c.call(CoordMsg.RunTest, 5000)
"coordinator: test done".print()
c.call(CoordMsg.Done, 5000)
"main: all done".print()
