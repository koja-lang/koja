fn main
  # Random.bytes returns correct byte count
  b16 = Random.bytes(16)
  print(b16.byte_size() == 16)

  b0 = Random.bytes(0)
  print(b0.byte_size() == 0)

  b1 = Random.bytes(1)
  print(b1.byte_size() == 1)

  # Random.int returns value in range
  n = Random.int(1, 10)
  print(n >= 1)
  print(n <= 10)

  # Single-value range returns that value
  print(Random.int(42, 42) == 42)
end
