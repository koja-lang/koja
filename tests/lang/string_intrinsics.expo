fn main
  s = "hello"

  # byte_length
  print(s.byte_length())

  # length
  print(s.length())

  # get
  print(s.get(0))
  print(s.get(4))

  # for loop iteration (Enumeration<String>)
  for c in "abc"
    print(c)
  end

  # slice
  print(s.slice(Range{start: 1, stop: 3}))

  # to_binary round-trip
  bin = "test".to_binary()
  match bin.to_string()
    Result.Ok(val) -> print(val)
    Result.Err(_) -> print("error")
  end

  # Int.parse
  match Int.parse("42")
    Result.Ok(val) -> print(val)
    Result.Err(_) -> print("error")
  end

  match Int.parse("not_a_number")
    Result.Ok(_) -> print("error")
    Result.Err(msg) -> print(msg)
  end

  # Float.parse
  match Float.parse("3.14")
    Result.Ok(val) -> print(val)
    Result.Err(_) -> print("error")
  end

  match Float.parse("bad")
    Result.Ok(_) -> print("error")
    Result.Err(msg) -> print(msg)
  end

  # Unicode support
  emoji = "héllo"
  print(emoji.length())
  print(emoji.byte_length())
  print(emoji.get(1))
end
