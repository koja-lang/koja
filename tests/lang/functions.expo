fn add(a: Int, b: Int) -> Int
  a + b
end

fn fib(n: Int) -> Int
  if n <= 1
    n
  else
    fib(n - 1) + fib(n - 2)
  end
end

fn early_return(x: Int) -> String
  if x > 10
    return "big"
  end
  "small"
end

fn main
  print(add(3, 4))
  print(fib(10))
  print(early_return(20))
  print(early_return(5))
end
