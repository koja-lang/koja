struct Response
  body: String
  status: Int
  version: String
end

fn build -> Response
  text = "hello" <> " world"
  Response{
    body: text,
    status: 200,
    version: "HTTP/1.1",
  }
end

fn main
  r = build()
  r.body.print()
  r.status.print()
  r.version.print()

  inner = "inner" <> " value"
  outer = "outer" <> " trailer"
  r2 = Response{body: inner, status: 404, version: outer}
  r2.body.print()
  r2.status.print()
  r2.version.print()
end
