struct Point
  x: Int
  y: Int
end

# Copy types: no ownership issues
a = 42
b = a
a.print()
b.print()

# Move type (struct): assignment moves
p1 = Point{x: 1, y: 2}
p2 = p1
# p1 is now moved -- using it would be a compile error

# Reassignment brings variable back to live
p1 = Point{x: 3, y: 4}
p1.x.print()

# Copy types in branches: no issues
n = 10

if true
  m = n
  m.print()
end

n.print()
