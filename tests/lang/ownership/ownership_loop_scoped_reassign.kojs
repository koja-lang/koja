# Regression guard for reassigning a heap-managed local first
# declared inside a while body. The post-loop write must skip the
# stale-value drop. On a zero-trip path the slot is uninitialized,
# and after a completed loop the back-edge already released the last
# iteration's value. The new value must still be released at scope
# exit, so the live-block count stays steady.

struct Rt
  @extern "C"
  fn koja_rt_live_blocks -> Int64
end

fn multi_trip -> Int
  i = 0
  while i < 4
    s = "iteration #{i}"
    i += 1
  end
  s = "after multi"
  s.length()
end

fn zero_trip -> Int
  i = 5
  while i < 3
    s = "never #{i}"
    i += 1
  end
  s = "after zero"
  s.length()
end

multi_trip().print()
zero_trip().print()

multi_trip()
zero_trip()
start = Rt.koja_rt_live_blocks()
i = 0

loop
  multi_trip()
  zero_trip()
  i += 1

  if i >= 200
    break
  end
end

finish = Rt.koja_rt_live_blocks()
(finish == start ? "steady: ok" : "steady: LEAK").print()
