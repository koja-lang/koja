# Value semantics: assigning an enum (incl. heap payloads) yields an
# independent value; the source and the copy format identically.
enum Tag
  Unset
  Name(String)
  Stamped {
    at: Int,
    by: String,
  }
end

fn main
  a = Tag.Name("hello")
  a_twin = a
  a.format().print()
  a_twin.format().print()

  b = Tag.Stamped{at: 42, by: "alice"}
  b_twin = b
  b.format().print()
  b_twin.format().print()

  c = Tag.Unset
  c_twin = c
  c.format().print()
  c_twin.format().print()
end
