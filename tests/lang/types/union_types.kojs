# Anonymous union types: widening coercion and match dispatch
struct Post
  title: String
end

struct Comment
  body: String
end

struct Ad
  url: String
end

fn display_item(item: Post | Comment | Ad) -> String
  match item
    _ -> "an item"
  end
end

fn widen_post(p: Post) -> Post | Comment
  p
end

fn accept_union(x: Post | Comment) -> String
  match x
    _ -> "ok"
  end
end

p = Post{title: "Hello"}
item: Post | Comment | Ad = p
display_item(item).print()

result = widen_post(Post{title: "Test"})
accept_union(result).print()
