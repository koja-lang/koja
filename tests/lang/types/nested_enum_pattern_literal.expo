enum TokenKind
  Ident(String)
  Number(Int)
end

enum IntPair
  Just(Int, Int)
  Nope
end

struct Classifier
end

impl Classifier
  fn classify(self, opt: Option<TokenKind>) -> String
    # Regression for GAPS "Nested enum pattern matching with literal
    # payloads": matching `Option.None` against an arm whose pattern is
    # `Option.Some(<literal-payload-shape>)` previously segfaulted because
    # the legacy emitter (and the Slice 5b IR-level lift) GEPed into the
    # outer variant's payload before the outer tag check gated the result.
    # Phase 4g pattern-CFG split fixes this by construction: payload
    # projections only execute when their enclosing tag check passed.
    match opt
      Option.Some(TokenKind.Ident("and")) -> "matched and"
      Option.Some(TokenKind.Ident(name)) -> name
      Option.Some(TokenKind.Number(0)) -> "zero"
      Option.Some(TokenKind.Number(_n)) -> "other number"
      Option.None -> "none"
    end
  end

  fn pair_kind(self, p: IntPair) -> String
    # Multi-arg tuple variant with literal in one slot: same gating
    # requirement -- the field projection for the second slot must not
    # execute when the first slot's literal compare already failed.
    match p
      IntPair.Just(0, _) -> "starts zero"
      IntPair.Just(1, 2) -> "one two"
      IntPair.Just(_a, _b) -> "other"
      IntPair.Nope -> "nope"
    end
  end
end

fn main
  c = Classifier{}

  none_opt: Option<TokenKind> = Option.None
  c.classify(none_opt).print()
  c.classify(Option.Some(TokenKind.Ident("and"))).print()
  c.classify(Option.Some(TokenKind.Ident("xyz"))).print()
  c.classify(Option.Some(TokenKind.Number(0))).print()
  c.classify(Option.Some(TokenKind.Number(7))).print()

  c.pair_kind(IntPair.Nope).print()
  c.pair_kind(IntPair.Just(0, 99)).print()
  c.pair_kind(IntPair.Just(1, 2)).print()
  c.pair_kind(IntPair.Just(3, 4)).print()
end
