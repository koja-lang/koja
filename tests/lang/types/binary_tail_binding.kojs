# Regression: greedy-tail binary bindings (`rest: Binary`) must allocate a
# full `[rc][bit_length][payload]` heap block. A prior codegen bug used the
# obsolete 8-byte, rc-less header, so the binding's payload pointer was 8
# bytes too low and dropping it freed a bogus base, corrupting the heap.
# Concatenation yields a heap binary (not a rodata literal), so the
# binding's drop actually runs rc-dec + free.

data: Binary = <<1::8>> <> <<2::8, 3::8, 4::8, 5::8>>

match data
  <<first::8, rest: Binary>> ->
    first.print()
    rest.byte_size().print()

  _ ->
    ()
end

stress(data, 0).print()

# Repeatedly allocate and drop a tail binding to surface heap corruption
# from a mis-sized allocation.

fn stress(data: Binary, count: Int) -> Int
  if count > 50
    return count
  end

  match data
    <<_first::8, rest: Binary>> -> stress(data, count + rest.byte_size())
    _ -> count
  end
end
