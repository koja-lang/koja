enum Sig
  Stop
end

enum Tick
  Beat(Int)
end

struct WorkerConfig
end

struct Worker
end

impl Process<WorkerConfig, Tick | Sig, String> for Worker
  fn start(move config: WorkerConfig) -> Result<Self, StopReason>
    Result.Ok(Worker{})
  end

  fn handle(move self, msg: Tick | Sig, from: Option<ReplyTo<String>>)
    -> Step<Self>

    match msg
      t: Tick ->
        match t
          Tick.Beat(n) ->
            "beat: #{n}".print()
            ReplyTo.reply(from, "ok")
            Step.Continue(self)
        end

      s: Sig ->
        match s
          Sig.Stop ->
            ReplyTo.reply(from, "bye")
            Step.Done(StopReason.Shutdown)
        end
    end
  end
end

struct Boss
  worker: Ref<Tick | Sig, String>
end

struct BossConfig
end

enum BossMsg
  Run
end

impl Process<BossConfig, BossMsg, String> for Boss
  fn start(move config: BossConfig) -> Result<Self, StopReason>
    w = spawn Worker.start(WorkerConfig{})
    Result.Ok(Boss{worker: w})
  end

  fn handle(move self, msg: BossMsg, from: Option<ReplyTo<String>>)
    -> Step<Self>
    match msg
      BossMsg.Run ->
        self.worker.call(Tick.Beat(1), 5000)
        self.worker.call(Sig.Stop, 5000)
        ReplyTo.reply(from, "done")
        Step.Done(StopReason.Shutdown)
    end
  end
end

fn main
  b = spawn Boss.start(BossConfig{})
  b.call(BossMsg.Run, 5000)
end
