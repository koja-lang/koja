alias Process.Step
alias Process.StopReason

struct CounterConfig
end

enum CounterMsg
  Increment
end

struct Counter
  count: Int
end

impl Process<CounterConfig, CounterMsg, Int> for Counter
  fn start(config: CounterConfig) -> Result<Self, StopReason>
    Result.Ok(Counter{count: 0})
  end

  fn handle(self, msg: CounterMsg, from: Option<ReplyTo<Int>>) -> Step<Self>
    match msg
      CounterMsg.Increment ->
        new_count = self.count + 1
        "count: #{new_count}".print()

        match from
          Option.Some(r) -> r.send(new_count)
          Option.None -> ()
        end

        Step.Continue(Counter{count: new_count})
    end
  end
end

counter = spawn Counter.start(CounterConfig{})
counter.cast(CounterMsg.Increment)
counter.cast(CounterMsg.Increment)
# Last message uses call to ensure the worker finishes before the script exits.
counter.call(CounterMsg.Increment, 5000)
