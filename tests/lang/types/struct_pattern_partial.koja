struct Point
  x: Int
  y: Int
end

struct Sieve
end

extend Sieve
  fn classify(self, p: Point) -> String
    # Partial-coverage semantics: any field omitted from the pattern is
    # an implicit wildcard. `Point{x: 5}` matches when `x == 5`
    # regardless of `y`. The empty `Point{}` arm matches any value.
    match p
      Point{x: 0, y: 0} -> "origin"
      Point{x: 5} -> "x is five"
      Point{y: 9} -> "y is nine"
      Point{} -> "any point"
    end
  end
end

fn main
  s = Sieve{}
  s.classify(Point{x: 0, y: 0}).print()
  s.classify(Point{x: 5, y: 1}).print()
  s.classify(Point{x: 5, y: 9}).print()
  s.classify(Point{x: 1, y: 9}).print()
  s.classify(Point{x: 7, y: 7}).print()
end
