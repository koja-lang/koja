fn main
  # Empty binary
  empty: Binary = <<>>
  print("empty ok")

  # Single byte
  one = <<0xFF>>
  print("one ok")

  # Multiple bytes
  header = <<0x48, 0x65, 0x6C, 0x6C, 0x6F>>
  print("header ok")

  # Sized segments
  wide = <<0x0102::16>>
  print("wide ok")

  # Byte unit
  chunk = <<3::2 byte>>
  print("chunk ok")

  # Mixed segments
  packet = <<0xFF, 0x00, 1024::16>>
  print("packet ok")

  # Little-endian
  le = <<0x0102::16 little>>
  print("le ok")

  # Signed
  neg = <<-1::8 signed>>
  print("neg ok")

  # Variable value in segment
  port: Int = 8080
  msg = <<0x01, port::16>>
  print("msg ok")

  # 32-bit segment
  big_val = <<0xDEADBEEF::32>>
  print("big ok")

  print("all binary tests passed")
end
