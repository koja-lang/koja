struct App
end

enum AppMsg
  Greet
end

impl Process<App, AppMsg, String> for App
  fn start(move config: App) -> Result<Self, StopReason>
    IO.puts("starting")
    Result.Ok(config)
  end

  fn handle(move self, msg: AppMsg, from: Option<ReplyTo<String>>) -> Step<Self>
    Step.Continue(self)
  end

  fn run(move self) -> StopReason
    IO.puts("running")
    StopReason.Normal
  end
end
