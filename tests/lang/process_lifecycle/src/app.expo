struct App
end

enum AppMsg
  Ping
end

impl Process<App, AppMsg, String> for App
  fn start(move config: App) -> Result<Self, StopReason>
    IO.puts("started")
    Result.Ok(config)
  end

  fn handle(move self, msg: AppMsg, from: Option<ReplyTo<String>>) -> Step<Self>
    Step.Continue(self)
  end

  fn handle_lifecycle(move self, event: Lifecycle) -> Step<Self>
    match event
      Lifecycle.Shutdown ->
        IO.puts("shutting down gracefully")
        Step.Done(StopReason.Shutdown)

      Lifecycle.Interrupt ->
        IO.puts("interrupted")
        Step.Done(StopReason.Shutdown)

      Lifecycle.Reload ->
        Step.Continue(self)
    end
  end
end
