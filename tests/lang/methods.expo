struct Point
  x: Int32
  y: Int32
end

impl Point
  fn distance_squared(self) -> Int32
    self.x * self.x + self.y * self.y
  end

  fn translate(self, dx: Int32, dy: Int32) -> Point
    Point{x: self.x + dx, y: self.y + dy}
  end
end

fn main
  p = Point{x: 3, y: 4}
  print(p.distance_squared())

  p2 = p.translate(1, 2)
  print(p2.x)
  print(p2.y)
end
