enum Color
  Red
  Green
  Blue
end

enum Shape
  Circle(Int)
  Rect(Int, Int)
end

fn color_name(c: Color) -> String
  match c
    Red -> "red"
    Green -> "green"
    Blue -> "blue"
  end
end

fn area(s: Shape) -> Int
  match s
    Shape.Circle(r) -> r * r * 3
    Shape.Rect(w, h) -> w * h
  end
end

fn main
  print(color_name(Color.Red))
  print(color_name(Color.Blue))

  print(area(Shape.Circle(5)))
  print(area(Shape.Rect(4, 6)))

  x = Option.Some(10)

  msg =
    match x
      Option.Some(v) when v > 5 -> "big some"
      Option.Some(_) -> "small some"
      Option.None -> "none"
    end

  print(msg)
end
