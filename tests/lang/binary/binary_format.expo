alias net.IPAddress

fn main
  # Empty binary
  empty: Binary = <<>>
  print(empty)

  # Single byte
  one = <<255>>
  print(one)

  # IPv4 address bytes
  ip = <<127, 0, 0, 1>>
  print(ip)

  # Multi-byte segment (big-endian 0x0102 = bytes 1, 2)
  wide = <<0x0102::16>>
  print(wide)

  # Bits via to_bits (byte-aligned)
  aligned_bits = <<10, 20>>.to_bits()
  print(aligned_bits)

  # Print binary inside a struct
  addr = IPAddress{bytes: <<192, 168, 1, 1>>}
  print(addr)
end
