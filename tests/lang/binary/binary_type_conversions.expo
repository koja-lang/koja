fn main
  # String.to_binary() – zero-cost widening
  s = "hello"
  bin = s.to_binary()
  match bin
    <<0x68, 0x65, 0x6C, 0x6C, 0x6F>> -> print("str to_binary ok")
    _ -> print("str to_binary fail")
  end

  # Binary.to_bits() – zero-cost widening
  b: Binary = <<0xAB, 0xCD>>
  bits = b.to_bits()
  print("to_bits ok")

  # Binary.to_string() – valid UTF-8
  valid: Binary = <<0x68, 0x69>>
  result = valid.to_string()
  match result
    Result.Ok(str) -> print(str)
    Result.Err(msg) -> print(msg)
  end

  # Binary.to_string() – invalid UTF-8
  invalid: Binary = <<0xFF, 0xFE>>
  result2 = invalid.to_string()
  match result2
    Result.Ok(_str) -> print("should not succeed")
    Result.Err(_msg) -> print("invalid utf8 caught")
  end

  # Bits.to_binary() – byte-aligned (success)
  aligned: Binary = <<0x01, 0x02>>
  as_bits = aligned.to_bits()
  result3 = as_bits.to_binary()
  match result3
    Result.Ok(b2) ->
      match b2
        <<0x01, 0x02>> -> print("bits to_binary ok")
        _ -> print("bits to_binary wrong bytes")
      end
    Result.Err(msg) -> print(msg)
  end

  print("all conversion tests passed")
end
