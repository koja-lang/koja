fn main
  m: Map<String, Int> = ["hello": 10, "world": 20]

  print("length: #{m.length()}")
  print("has hello: #{m.has?("hello")}")
  print("has world: #{m.has?("world")}")
  print("has missing: #{m.has?("missing")}")

  empty: Map<String, Int> = [:]
  print("empty length: #{empty.length()}")
  print("empty empty?: #{empty.empty?()}")
end
