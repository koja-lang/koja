fn main
  m: Map<String, Int> = Map.new()
  m = m.put("hello", 10)
  m = m.put("world", 20)
  m = m.put("hello", 30)

  print("length: #{m.length()}")
  print("has hello: #{m.has?("hello")}")
  print("has missing: #{m.has?("missing")}")
  print("empty: #{m.empty?()}")

  m = m.remove("hello")
  print("after remove length: #{m.length()}")
  print("has hello after remove: #{m.has?("hello")}")
end
