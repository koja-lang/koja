enum JsonValue
  Null
  JBool(Bool)
  JInt(Int)
  JStr(String)
  JArr(List<JsonValue>)
  JObj(Map<String, JsonValue>)
end

fn print_json(v: JsonValue)
  match v
    JsonValue.Null ->
      "null".print()

    JsonValue.JBool(b) ->
      if b
        "true".print()
      else
        "false".print()
      end

    JsonValue.JInt(n) ->
      n.print()

    JsonValue.JStr(s) ->
      s.print()

    JsonValue.JArr(items) ->
      "[".print()
      i = 0

      while i < items.length()
        match items.get(i)
          Option.Some(item) -> print_json(item)
          Option.None -> ()
        end

        i += 1
      end

      "]".print()

    JsonValue.JObj(m) ->
      "{object}".print()
  end
end

arr = [JsonValue.JInt(1), JsonValue.JStr("hello"), JsonValue.JBool(true)]
obj: Map<String, JsonValue> = [
  "name": JsonValue.JStr("Koja"), "tags": JsonValue.JArr(arr),
  "active": JsonValue.JBool(true)
]
root = JsonValue.JObj(obj)

print_json(JsonValue.Null)
print_json(JsonValue.JInt(42))
print_json(JsonValue.JArr([JsonValue.JInt(1), JsonValue.JInt(2)]))
print_json(root)
