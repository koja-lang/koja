fn main
  # List.new + append
  list: List<Int> = List.new()
  list = list.append(10)
  list = list.append(20)
  list = list.append(30)

  print(list.length())
  print(list.get(0).unwrap())
  print(list.get(1).unwrap())
  print(list.get(2).unwrap())
  print(list.empty?())

  # literal syntax
  nums = [10, 20, 30]
  print(nums.length())
  print(nums.get(0).unwrap())
  print(nums.get(1).unwrap())
  print(nums.get(2).unwrap())

  # empty literal
  empty: List<Int> = []
  print(empty.length())
  print(empty.empty?())

  # string list
  words = ["hello", "world"]
  print(words.get(0).unwrap())
  print(words.get(1).unwrap())

  # single-element literal
  single = [42]
  print(single.length())
  print(single.get(0).unwrap())
end
