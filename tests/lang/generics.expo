fn identity<T>(x: T) -> T
  x
end

fn make_pair<A, B>(a: A, b: B) -> Pair<A, B>
  Pair{first: a, second: b}
end

fn main
  print(identity(42))
  print(identity("hello"))
  print(identity(true))

  p = make_pair(10, 20)
  print(p.first)
  print(p.second)

  p2 = make_pair("foo", 100)
  print(p2.first)
  print(p2.second)
end
