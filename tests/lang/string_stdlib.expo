fn main
  # empty?
  print("".empty?())
  print("hello".empty?())

  # at
  match "hello".at(1)
    Option.Some(c) -> print(c)
    Option.None -> print("none")
  end
  match "hello".at(10)
    Option.Some(c) -> print(c)
    Option.None -> print("none")
  end
  match "hello".at(-1)
    Option.Some(_) -> print("some")
    Option.None -> print("none")
  end

  # contains?
  print("hello world".contains?("world"))
  print("hello world".contains?("xyz"))
  print("hello".contains?(""))
  print("".contains?("a"))

  # starts_with?
  print("hello world".starts_with?("hello"))
  print("hello world".starts_with?("world"))
  print("hello".starts_with?(""))
  print("hi".starts_with?("hello"))

  # ends_with?
  print("hello world".ends_with?("world"))
  print("hello world".ends_with?("hello"))
  print("hello".ends_with?(""))
  print("hi".ends_with?("hello"))

  # trim_start
  print("  hello  ".trim_start())
  print("hello".trim_start())

  # trim_end
  print("  hello  ".trim_end())
  print("hello".trim_end())

  # trim
  print("  hello  ".trim())
  print("hello".trim())

  # upcase
  print("hello".upcase())
  print("Hello World 123".upcase())

  # downcase
  print("HELLO".downcase())
  print("Hello World 123".downcase())

  # replace
  print("hello world".replace("world", "expo"))
  print("aaa".replace("a", "bb"))
  print("hello".replace("xyz", "!"))
  print("hello".replace("", "!"))

  # reverse
  print("hello".reverse())
  print("".reverse())
  print("a".reverse())

  # split
  parts: List<String> = "a,b,c".split(",")
  print(parts.length())
  print(parts.get(0).unwrap())
  print(parts.get(1).unwrap())
  print(parts.get(2).unwrap())

  parts = "hi".split("")
  print(parts.length())
  print(parts.get(0).unwrap())
  print(parts.get(1).unwrap())

  # join
  join_parts: List<String> = ["a", "b", "c"]
  print(String.join(join_parts, ", "))
  join_one: List<String> = ["one"]
  print(String.join(join_one, "-"))
  join_empty: List<String> = List.new()
  print(String.join(join_empty, ","))

  # alpha?
  print("hello".alpha?())
  print("hello123".alpha?())
  print("".alpha?())

  # digit?
  print("123".digit?())
  print("12a".digit?())

  # whitespace?
  print(" \t\n".whitespace?())
  print(" x ".whitespace?())

  # codepoints
  cp: List<String> = "abc".codepoints()
  print(cp.length())
  print(cp.get(0).unwrap())
  print(cp.get(2).unwrap())

  # graphemes
  cp = "hi".graphemes()
  print(cp.length())
  print(cp.get(0).unwrap())

  # to_int
  match "42".to_int()
    Result.Ok(val) -> print(val)
    Result.Err(_) -> print("error")
  end
  match "bad".to_int()
    Result.Ok(_) -> print("ok")
    Result.Err(msg) -> print(msg)
  end

  # to_float
  match "3.14".to_float()
    Result.Ok(val) -> print(val)
    Result.Err(_) -> print("error")
  end
  match "bad".to_float()
    Result.Ok(_) -> print("ok")
    Result.Err(msg) -> print(msg)
  end
end
