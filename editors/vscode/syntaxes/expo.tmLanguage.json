{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Expo",
  "scopeName": "source.expo",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#annotations" },
    { "include": "#keywords" },
    { "include": "#operators" },
    { "include": "#primitive-types" },
    { "include": "#types" },
    { "include": "#module-constants" },
    { "include": "#module-qualified-call" },
    { "include": "#import-path" },
    { "include": "#function-call" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.expo",
          "match": "#.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.triple.expo",
          "begin": "\"\"\"",
          "end": "\"\"\"",
          "patterns": [
            { "include": "#string-interpolation" },
            { "include": "#string-escape" }
          ]
        },
        {
          "name": "string.quoted.double.expo",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "include": "#string-interpolation" },
            { "include": "#string-escape" }
          ]
        }
      ]
    },
    "string-interpolation": {
      "patterns": [
        {
          "name": "meta.interpolation.expo",
          "begin": "#\\{",
          "end": "\\}",
          "beginCaptures": {
            "0": { "name": "punctuation.section.interpolation.begin.expo" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.section.interpolation.end.expo" }
          },
          "patterns": [{ "include": "source.expo" }]
        }
      ]
    },
    "string-escape": {
      "patterns": [
        {
          "name": "constant.character.escape.expo",
          "match": "\\\\[nrt\\\\\"#0]"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.expo",
          "match": "\\b0x[0-9a-fA-F][0-9a-fA-F_]*\\b"
        },
        {
          "name": "constant.numeric.binary.expo",
          "match": "\\b0b[01][01_]*\\b"
        },
        {
          "name": "constant.numeric.float.expo",
          "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*\\b"
        },
        {
          "name": "constant.numeric.integer.expo",
          "match": "\\b[0-9][0-9_]*\\b"
        }
      ]
    },
    "annotations": {
      "patterns": [
        {
          "name": "storage.type.annotation.expo",
          "match": "@\\w+"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.flow.expo",
          "match": "\\b(if|else|unless|match|cond|when|return|break)\\b"
        },
        {
          "name": "keyword.control.loop.expo",
          "match": "\\b(for|loop|while|in)\\b"
        },
        {
          "name": "keyword.control.concurrency.expo",
          "match": "\\b(spawn|await|receive|move)\\b"
        },
        {
          "name": "keyword.other.fn.expo",
          "match": "\\b(fn|priv)\\b"
        },
        {
          "name": "keyword.other.end.expo",
          "match": "\\bend\\b"
        },
        {
          "name": "keyword.other.expo",
          "match": "\\b(const|impl|type|shared|import)\\b"
        },
        {
          "name": "storage.type.expo",
          "match": "\\b(struct|enum|arena)\\b"
        },
        {
          "name": "keyword.operator.logical.expo",
          "match": "\\b(and|or|not)\\b"
        },
        {
          "name": "constant.language.boolean.expo",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.none.expo",
          "match": "\\bnone\\b"
        },
        {
          "name": "variable.language.self.expo",
          "match": "\\bself\\b"
        },
        {
          "name": "variable.language.ref.expo",
          "match": "\\bref\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.pipe.expo",
          "match": "\\|>"
        },
        {
          "name": "keyword.operator.arrow.expo",
          "match": "->"
        },
        {
          "name": "keyword.operator.comparison.expo",
          "match": "[!=]=|[<>]=?"
        },
        {
          "name": "keyword.operator.assignment.compound.expo",
          "match": "[+\\-*/%]="
        },
        {
          "name": "keyword.operator.assignment.expo",
          "match": "="
        },
        {
          "name": "keyword.operator.arithmetic.expo",
          "match": "[+\\-*/%]"
        },
        {
          "name": "keyword.operator.optional.expo",
          "match": "\\?"
        }
      ]
    },
    "primitive-types": {
      "patterns": [
        {
          "name": "support.type.primitive.expo",
          "match": "\\b(bool|f32|f64|i8|i16|i32|i64|string|u8|u16|u32|u64)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "entity.name.type.expo",
          "match": "\\b[A-Z][a-zA-Z0-9]*\\b"
        }
      ]
    },
    "module-constants": {
      "patterns": [
        {
          "name": "constant.other.expo",
          "match": "\\b[A-Z][A-Z0-9_]{1,}\\b"
        }
      ]
    },
    "import-path": {
      "patterns": [
        {
          "match": "(?<=\\bimport\\s)([a-z_][a-z0-9_]*(?:\\.[a-z_][a-z0-9_]*)*)",
          "captures": {
            "1": { "name": "entity.name.namespace.expo" }
          }
        }
      ]
    },
    "module-qualified-call": {
      "patterns": [
        {
          "match": "\\b([a-z_][a-z0-9_]*)\\.([a-z_][a-z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.namespace.expo" },
            "2": { "name": "entity.name.function.expo" }
          }
        }
      ]
    },
    "function-call": {
      "patterns": [
        {
          "name": "meta.function-call.expo",
          "match": "\\b([a-z_][a-z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.expo" }
          }
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.expo",
          "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
